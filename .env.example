# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# WHATSAPP_TOKEN: Meta WhatsApp Cloud API access token
WHATSAPP_TOKEN=your_whatsapp_temporary_or_permanent_access_token_here

# PHONE_NUMBER_ID: Meta unique Phone Number ID
PHONE_NUMBER_ID=your_phone_number_id_here

# VERIFY_TOKEN: Token defined in Meta developers console to verify Webhook callback URLs
VERIFY_TOKEN=sharma_store_token

# PORT: The port that the local Node.js server listens to
PORT=3000

# MONGODB_URI: MongoDB connection URI for production (leave empty for local JSON/db.json usage)
MONGODB_URI=mongodb://username:password@host:27017/dbname
