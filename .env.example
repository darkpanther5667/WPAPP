# ── GEMINI AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── WHATSAPP CLOUD API ─────────────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
VERIFY_TOKEN=your_webhook_verify_token_here
WHATSAPP_APP_SECRET=your_whatsapp_app_secret_here

# ── AUTH / SECURITY ────────────────────────────────────────────────────────────
MOBILE_API_KEY=generate_a_random_64_char_key
ADMIN_KEY=generate_another_random_64_char_key

# ── GOOGLE OAUTH (for web login) ───────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# 1. Create a project (or use existing)
# 2. Enable "Google+ API" or "Google Identity" API
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Add authorized redirect URIs:
#    - http://localhost:3000 (for dev)
#    - https://your-domain.com (for production)
#    - https://wpapp-xz9l.onrender.com/api/auth/google (for API)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://your-app.onrender.com

# ── PUBLIC URL (used for PDF/WhatsApp absolute links) ──────────────────────────
PUBLIC_BASE_URL=https://your-app.onrender.com

# ── MONGODB (leave empty to use local db.json) ─────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ── PORT (Render sets this automatically) ──────────────────────────────────────
PORT=3000
